rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function myProfilePath() {
      return /databases/$(database)/documents/profiles/$(request.auth.uid);
    }

    function hasMyProfile() {
      return signedIn() && exists(myProfilePath());
    }

    function me() {
      return get(myProfilePath()).data;
    }

    function myRole() {
      return hasMyProfile() && me().role is string ? me().role.lower() : '';
    }

    function isPreparadorRole(role) {
      // Aceita variações comuns vindas de edição manual no console.
      // Observação: lower() mantém acentos; por isso cobrimos ambas as grafias.
      return role == 'preparador' ||
        role == 'prep' ||
        role == 'preparador fisico' ||
        role == 'preparador físico';
    }

    function isManagement() {
      return hasMyProfile() && (
        myRole() == 'admin' ||
        myRole() == 'coordenador' ||
        isPreparadorRole(myRole())
      );
    }

    function isPreparador() {
      return hasMyProfile() && isPreparadorRole(myRole());
    }

    function isAdmin() {
      return hasMyProfile() && myRole() == 'admin';
    }

    match /profiles/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isManagement());
      allow create: if signedIn() && request.auth.uid == uid;
      function changedKeys() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }

      function isAllowedSelfUpdate() {
        // Jogador pode editar dados pessoais e métricas atuais (não objetivos).
        return changedKeys().hasOnly([
          'displayName',
          'sectors',
          'heightCm',
          'weightKg',
          'bodyFatPct',
          'leanMassKg',
          'avgSpeed',
          'maxSpeed',
          'updatedAt'
        ]);
      }

      function isAllowedPreparadorUpdate() {
        // Preparador pode editar setores e métricas, incluindo objetivos.
        return changedKeys().hasOnly([
          'displayName',
          'sectors',
          'heightCm',
          'weightKg',
          'bodyFatPct',
          'leanMassKg',
          'avgSpeed',
          'maxSpeed',
          'targetWeightKg',
          'targetBodyFatPct',
          'targetLeanMassKg',
          'updatedAt'
        ]);
      }

      allow update: if signedIn() && (
        isAdmin() ||
        (
          isPreparador() &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.email == resource.data.email
          && isAllowedPreparadorUpdate()
        ) ||
        (
          request.auth.uid == uid &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.email == resource.data.email
          && isAllowedSelfUpdate()
        )
      );
    }

    match /analyses/{id} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid || isManagement()
      );
      allow create: if signedIn() &&
        isPreparador() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /trainings/{id} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid || isManagement()
      );
      allow create: if signedIn() &&
        isPreparador() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /trainingTemplates/{id} {
      allow read: if signedIn() && isPreparador() && resource.data.createdBy == request.auth.uid;
      allow create: if signedIn() &&
        isPreparador() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /trainingCompletions/{id} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid || isManagement()
      );
      allow create, update: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    match /dailyPoints/{id} {
      allow read: if signedIn();
      allow create, update: if signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.points in [0, 5, 10];
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
