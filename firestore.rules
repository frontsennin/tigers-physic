rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function myProfilePath() {
      return /databases/$(database)/documents/profiles/$(request.auth.uid);
    }

    function hasMyProfile() {
      return signedIn() && exists(myProfilePath());
    }

    function me() {
      return get(myProfilePath()).data;
    }

    function isManagement() {
      return hasMyProfile() && me().role in ['admin', 'coordenador', 'preparador'];
    }

    function isPreparador() {
      return hasMyProfile() && me().role == 'preparador';
    }

    function isAdmin() {
      return hasMyProfile() && me().role == 'admin';
    }

    match /profiles/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isManagement());
      allow create: if signedIn() && request.auth.uid == uid;
      function changedKeys() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }

      function isAllowedSelfUpdate() {
        // Jogador pode editar dados pessoais e métricas atuais (não objetivos).
        return changedKeys().hasOnly([
          'displayName',
          'sectors',
          'heightCm',
          'weightKg',
          'bodyFatPct',
          'leanMassKg',
          'avgSpeed',
          'maxSpeed',
          'updatedAt'
        ]);
      }

      function isAllowedPreparadorUpdate() {
        // Preparador pode editar setores e métricas, incluindo objetivos.
        return changedKeys().hasOnly([
          'displayName',
          'sectors',
          'heightCm',
          'weightKg',
          'bodyFatPct',
          'leanMassKg',
          'avgSpeed',
          'maxSpeed',
          'targetWeightKg',
          'targetBodyFatPct',
          'targetLeanMassKg',
          'updatedAt'
        ]);
      }

      allow update: if signedIn() && (
        isAdmin() ||
        (
          isPreparador() &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.email == resource.data.email
          && isAllowedPreparadorUpdate()
        ) ||
        (
          request.auth.uid == uid &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.email == resource.data.email
          && isAllowedSelfUpdate()
        )
      );
    }

    match /analyses/{id} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid || isManagement()
      );
      allow create: if signedIn() &&
        isPreparador() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /trainings/{id} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid || isManagement()
      );
      allow create: if signedIn() &&
        isPreparador() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /trainingCompletions/{id} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid || isManagement()
      );
      allow create, update: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
    }
  }
}
